//#endif
#define RCC_BASE_ADDRESS		0x40023800UL
#define RCC_APB2_ENR_OFFSET		0x44U
#define RCC_APB2_ENR_ADDRESS	(RCC_BASE_ADDRESS + RCC_APB2_ENR_OFFSET)

#define ADC_BASE_ADDRESS 		0x40012000UL
#define ADC_CR1_REG_OFFSET 		0x04U
#define ADC_CR1_REG_ADDRESS		(ADC_BASE_ADDRESS + ADC_CR1_REG_OFFSET)

#define ADC_CR1_BIT_8			8u
#define RCC_ADC_BIT				8u

int main(void)
{
	uint32_t *AdcCr1Reg_pu32 = (uint32_t*)ADC_CR1_REG_ADDRESS;
	uint32_t *RccApb2Enr_pu32 = (uint32_t*)RCC_APB2_ENR_ADDRESS;

	// 1. Enable perp CLK
	*RccApb2Enr_pu32 |= (1 << RCC_ADC_BIT);

	// 2. Enable ADC1
	*AdcCr1Reg_pu32 |= (1 << ADC_CR1_BIT_8);

    /* Loop forever */
	for(;;);
}
