#include <stdint.h>

#define RCC_BASE_ADDRESS		0x40023800UL
#define RCC_CFGR_REG_OFFSET		0x08UL
#define RCC_CFGR_REG_ADDRESS	(RCC_BASE_ADDRESS + RCC_CFGR_REG_OFFSET)

#define RCC_AHB1_OFFSET			0x30U
#define GPIOA_BASE_ADDRESS		0x40020000UL
#define GPIOA_REG_OFFSET		0x00


int main(void)
{
	uint32_t *pRccCfgrReg_u32 = (uint32_t *) RCC_CFGR_REG_ADDRESS;

	/* 1. Configure the RCC_CFGR MCO1 bit fields to select HSI as clock source
	 * The MCO1 register stands for Microcontroller clock output 1
	 * 00: HSI clock selected
	 * 01: LSE oscillator selected
	 * 10: HSE oscillator clock selected
	 * 11: PLL clock selected
	 */
	*pRccCfgrReg_u32 &= ~(0x03 << 21); // Clear bit position 21 and 22

	/* 2. Configure PA8 to AF0 mode to behave as MCO1 signal
	 */
	// a) Enable the peripheral Clock for GPIO-A peripheral
	uint32_t *pRCCAhbEnr = (uint32_t*)(RCC_BASE_ADDRESS + RCC_AHB1_OFFSET);
	*pRCCAhbEnr |= (1 << 0);

	// b) Configure the mode GPIOA pin 8 as alternate function mode
	uint32_t *pGPIOAModeReg = (uint32_t*)(GPIOA_BASE_ADDRESS + GPIOA_REG_OFFSET);
	*pGPIOAModeReg &= ~(0x03 << 16); // Clear bit 16 and 17
	*pGPIOAModeReg |= (0x02 << 16);  // Set bit 17

	// c) Configure the alternation function register to set the mode 0 for PA8
	uint32_t *pGPIOAAltFunHighReg = (uint32_t*)(GPIOA_BASE_ADDRESS + 0x24);
	*pGPIOAAltFunHighReg &= ~( 0xf << 0);







    /* Loop forever */
	for(;;);
}
