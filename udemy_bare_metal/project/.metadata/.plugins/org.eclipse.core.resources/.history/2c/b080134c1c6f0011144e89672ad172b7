#ifndef INC_STM32F407XX_H_
#define INC_STM32F407XX_H_

/* Bus addresses of Flash and SRAM memories */

#define FLASH_BASE_ADDR			0x08000000U
#define SRAM1_BASE_ADDR			0x20000000U
#define SRAM1_SIZE				0x0001C000U
#define SRAM2_BASE_ADDR			(SRAM1_BASE_ADDR + SRAM1_SIZE)
#define ROM_BASE_ADDR			0x1FFF0000U

/* AHBx and APBx Bus peripheral base addresses */

#define PERIPHERAL_BASE_ADDR	0x40000000U
#define APB1PERIPH_BASE_ADDR	PERIPHERAL_BASE_ADDR
#define APB2PERIPH_OFFSET		0x00010000U
#define APB2PERIPH_BASE_ADDR
#define AHB1PERIPH_BASE_ADDR
#define AHB2PERIPH_BASE_ADDR

#endif /* INC_STM32F407XX_H_ */
